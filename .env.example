# ─────────────────────────────────────────────────────────────────────────────
# PERMATEL — Variables d'environnement (template de déploiement)
#
# Copier en .env à la racine, renseigner les valeurs, puis `docker compose up -d --build`.
# ⚠  Ne jamais committer le .env réel.  Secrets OBLIGATOIRES : POSTGRES_PASSWORD,
#    JWT_SECRET_KEY, SETTINGS_ENCRYPTION_KEY (+ DOMAIN/ACME_EMAIL si profil proxy).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (interne, non exposé en prod) ──────────────────────────────────
POSTGRES_DB=permatel
POSTGRES_USER=permatel_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Reverse-proxy TLS (Traefik) — activable/désactivable ──────────────────────
#   COMPOSE_PROFILES=proxy  → Traefik gère le TLS Let's Encrypt sur 80/443
#   COMPOSE_PROFILES=       → pas de Traefik ; frontend exposé sur FRONTEND_BIND:FRONTEND_PORT
COMPOSE_PROFILES=proxy
# Requis SI profil proxy : DNS A/AAAA de DOMAIN → hôte ; ACME_EMAIL = avis Let's Encrypt
DOMAIN=permatel.exemple.com
ACME_EMAIL=admin@exemple.com
# Exposition directe du frontend (mode SANS Traefik). 127.0.0.1 = non exposé sur Internet.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080

# ── Sécurité / secrets ────────────────────────────────────────────────────────
# Générer : python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_token_hex_64
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
# ⚠ STABLE & SECRÈTE : la changer rend illisibles les données chiffrées (SMTP/IMAP, emails, PJ).
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_generate_token_hex_32

# ── Application ───────────────────────────────────────────────────────────────
FLASK_APP=app
FLASK_ENV=production            # development | production | testing
APP_NAME=PERMATEL API
APP_VERSION=1.4.0
GUNICORN_WORKERS=3              # ≈ 2×CPU + 1
AUTO_MIGRATE=true              # géré par l'entrypoint en prod

# ── JWT / Session ─────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=1
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ── Anti-brute-force /auth/login ──────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# ── Onboarding / Support ──────────────────────────────────────────────────────
# URL publique (liens d'invitation) — = https://<DOMAIN> en prod via Traefik.
FRONTEND_BASE_URL=https://permatel.exemple.com
SUPPORT_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# En prod same-origin (Traefik+Nginx proxifient /api) : URL HTTPS publique.
CORS_ORIGINS=https://permatel.exemple.com

# ── Frontend (build) ──────────────────────────────────────────────────────────
# En prod, VITE_API_BASE_URL est figé à /api au build (proxy same-origin) ;
# la valeur ci-dessous ne sert qu'au dev (vite + flask séparés).
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=PERMATEL
VITE_APP_VERSION=1.4.0
VITE_INACTIVITY_TIMEOUT_MINUTES=30
