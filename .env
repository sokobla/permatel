# ─────────────────────────────────────────────────────────────────────────────
# PERMATEL — Environnement de développement local
# Utilisé par docker-compose.yml
# ⚠  Ne pas committer ce fichier  ⚠
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=permatel
POSTGRES_USER=permatel_user
POSTGRES_PASSWORD=permatel_pass
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Flask
FLASK_APP=app
FLASK_ENV=development
APP_NAME=PERMATEL API
APP_VERSION=1.0.0
PORT=5000

# Timeouts
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
FRONTEND_PORT=8080
