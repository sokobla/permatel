# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  PERMATEL — Configuration backend (.env)                                 ║
# ║  ⚠ Ne jamais committer ce fichier. Voir .env.example pour le template.   ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=PERMATEL API
APP_VERSION=1.0.0
FLASK_APP=app
# Environnement : development | production | testing
FLASK_ENV=development
DEBUG=True
BINDADDR=0.0.0.0
PORT=5000

# ── Initialisation de la base au démarrage ────────────────────────────────────
# AUTO_MIGRATE : applique les migrations en attente si la base existe déjà.
# (Base vide au 1er démarrage → schéma créé + amorce unique : tenant Root + admin global.)
AUTO_MIGRATE=true

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_USER=permatel_user
DB_PASSWORD=permatel_pass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=permatel
# DATABASE_URL est prioritaire (utilisé par Docker) ; sinon construit depuis DB_*.
DATABASE_URL=postgresql://permatel_user:permatel_pass@localhost:5432/permatel

# ── Sécurité / JWT ────────────────────────────────────────────────────────────
# Clé de signature des tokens JWT. ⚠ À régénérer en production.
JWT_SECRET_KEY=dev-secret-key-change-in-production
# Durées de vie des tokens et de la session.
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=1
# Délai d'inactivité avant expiration de session (côté serveur ET auto-logout client).
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ── Chiffrement des secrets & données (RGPD) ──────────────────────────────────
# Clé dédiée au chiffrement au repos (Fernet) : mots de passe SMTP/IMAP,
# contenu des emails (objet, corps, HTML) et pièces jointes.
# ⚠ STABLE & SECRÈTE : si elle change, les données déjà chiffrées deviennent
#   illisibles. À sauvegarder précieusement. À défaut, JWT_SECRET_KEY est utilisé.
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SETTINGS_ENCRYPTION_KEY=e77be124fdb626a919642a7947aa2cfccb6608cddcdeb86826ad0b49d9f1d2c5

# ── Anti-brute-force /auth/login ──────────────────────────────────────────────
# Verrouillage temporaire après trop d'échecs de connexion.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# ── Support ───────────────────────────────────────────────────────────────────
# Destinataire de repli des demandes « Contacter le support » si aucun tenant
# ne définit son propre support_email.
SUPPORT_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_HEADERS='Content-Type'
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
