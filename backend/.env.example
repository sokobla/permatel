# ─────────────────────────────────────────────────────────────────────────────
# PERMATEL — Variables d'environnement (template)
#
# Copier ce fichier en .env à la racine du projet et renseigner toutes les
# valeurs avant de lancer `docker-compose up`.
#
# ⚠  Ne jamais committer le fichier .env  ⚠
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# En production (docker compose), la base N'EST PAS exposée sur l'hôte.
POSTGRES_DB=permatel
POSTGRES_USER=permatel_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Déploiement (docker compose prod) ─────────────────────────────────────────
# Reverse-proxy TLS Traefik ACTIVABLE/DÉSACTIVABLE :
#   COMPOSE_PROFILES=proxy  → Traefik gère le TLS (Let's Encrypt) sur 80/443.
#   COMPOSE_PROFILES=       → Traefik désactivé ; gérez le TLS autrement (voir ci-dessous).
COMPOSE_PROFILES=proxy

# Requis UNIQUEMENT si le profil "proxy" est actif :
#   DOMAIN doit pointer (DNS A/AAAA) vers l'hôte ; ACME_EMAIL reçoit les avis ACME.
DOMAIN=permatel.exemple.com
ACME_EMAIL=admin@exemple.com

# Exposition directe du frontend (utile SANS Traefik, pour un proxy/LB externe).
# Bind 127.0.0.1 par défaut (non exposé sur Internet) ; 0.0.0.0 si LB sur autre hôte.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080

# Nombre de workers Gunicorn (≈ 2×CPU + 1).
GUNICORN_WORKERS=3
# URL publique (liens d'invitation d'onboarding) — HTTPS via Traefik, ou votre URL si TLS externe.
FRONTEND_BASE_URL=https://permatel.exemple.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer une clé forte : python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret

# ── Flask / Application ───────────────────────────────────────────────────────
FLASK_APP=app
FLASK_ENV=development        # development | production | testing
APP_NAME=PERMATEL API
APP_VERSION=1.0.0
PORT=5000

# ── Initialisation de la base au démarrage ────────────────────────────────────
# AUTO_MIGRATE : applique les migrations en attente si la base existe déjà.
# (Base vide au 1er démarrage → schéma créé + amorce unique : tenant Root + admin global.)
AUTO_MIGRATE=true

# ── JWT / Session timeouts ────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=1
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ── Chiffrement des secrets & données (RGPD) ──────────────────────────────────
# Clé Fernet dédiée : chiffre les mots de passe SMTP/IMAP, le contenu des emails
# (objet, corps, HTML) et les pièces jointes au repos.
# ⚠ STABLE & SECRÈTE : si elle change, les données chiffrées deviennent illisibles.
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_generate_a_dedicated_encryption_key

# ── Anti-brute-force /auth/login ──────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# ── Support ───────────────────────────────────────────────────────────────────
# Destinataire de repli « Contacter le support » (si un tenant n'a pas de support_email)
SUPPORT_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules).
# En production same-origin (Traefik+Nginx proxifient /api), mettre l'URL HTTPS publique.
CORS_ORIGINS=https://permatel.exemple.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# NOTE prod : VITE_API_BASE_URL est figé à /api au build (proxy Nginx same-origin) ;
# la valeur ci-dessous ne sert qu'au dev (vite + flask séparés).
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=PERMATEL
VITE_APP_VERSION=1.4.0
VITE_INACTIVITY_TIMEOUT_MINUTES=30
